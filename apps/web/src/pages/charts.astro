---
import AreaApp from '../apps/area/app';
import BoxPlotApp from '../apps/box-plot/app';
import CandlestickApp from '../apps/candlestick/app';
import GaugeApp from '../apps/gauge/app';
import ParallelCoordsApp from '../apps/parallel-coords/app';
import CalendarHeatmapApp from '../apps/calendar-heatmap/app';
import ZoomableLineApp from '../apps/zoomable-line/app';
import PhyllotaxisApp from '../apps/phyllotaxis/app';
import HistogramApp from '../apps/histogram/app';
import SymbolScatterApp from '../apps/symbol-scatter/app';
import TidyTreeApp from '../apps/tidy-tree/app';
import TimelineApp from '../apps/timeline/app';
import ViolinApp from '../apps/violin/app';
import RadialTreeApp from '../apps/radial-tree/app';
import WaterfallApp from '../apps/waterfall/app';
import LogScatterApp from '../apps/log-scatter/app';
import CurveComparisonApp from '../apps/curve-comparison/app';
import DivergingBarApp from '../apps/diverging-bar/app';
import ThresholdBarApp from '../apps/threshold-bar/app';
import EasingCurvesApp from '../apps/easing-curves/app';
import ColorSpacesApp from '../apps/color-spaces/app';
import DensityContourApp from '../apps/density-contour/app';
import VoronoiDiagramApp from '../apps/voronoi-diagram/app';
import MapProjectionsApp from '../apps/map-projections/app';
import LinkedChartsApp from '../apps/linked-charts/app';
import BulletApp from '../apps/bullet/app';
import BumpApp from '../apps/bump/app';
import ArcDiagramApp from '../apps/arc-diagram/app';
import DivergingStackedBarApp from '../apps/diverging-stacked-bar/app';
import CorrelationMatrixApp from '../apps/correlation-matrix/app';
import WindRoseApp from '../apps/wind-rose/app';
import BarApp from '../apps/bar/app';
import BubbleApp from '../apps/bubble/app';
import DonutApp from '../apps/donut/app';
import ForceGraphApp from '../apps/force-graph/app';
import ChordApp from '../apps/chord/app';
import SankeyApp from '../apps/sankey/app';
import PackedCirclesApp from '../apps/packed-circles/app';
import HeatmapApp from '../apps/heatmap/app';
import RadarApp from '../apps/radar/app';
import StreamgraphApp from '../apps/streamgraph/app';
import SunburstApp from '../apps/sunburst/app';
import TreemapApp from '../apps/treemap/app';
import LineApp from '../apps/line/app';
import ScatterApp from '../apps/scatter/app';
import * as gridStyles from '../apps/charts/charts.css';
import Layout from '../layouts/Layout.astro';
import * as layoutStyles from '../layouts/layout.css';
---

<Layout title="Charts — Astro + FoldKit">
  <h1 class={layoutStyles.heading}>Charts</h1>
  <div class={gridStyles.grid}>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Budget breakdown</p>
      <DonutApp client:load noMeta/>
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly figures</p>
      <BarApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly trend</p>
      <LineApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly revenue</p>
      <AreaApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Experience vs salary</p>
      <ScatterApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Price vs rating by sales</p>
      <BubbleApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>JS ecosystem</p>
      <ForceGraphApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Language comparison</p>
      <RadarApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Tech revenue by segment</p>
      <TreemapApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>JS framework downloads</p>
      <StreamgraphApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Tech market cap by sector</p>
      <SunburstApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Traffic by hour &amp; day</p>
      <HeatmapApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Tech sector cross-investment</p>
      <ChordApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>UK energy flow</p>
      <SankeyApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Language families</p>
      <PackedCirclesApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Salary by level</p>
      <BoxPlotApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>NVDA Apr – May</p>
      <CandlestickApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Annual P&amp;L</p>
      <WaterfallApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>System metrics</p>
      <GaugeApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Car comparison</p>
      <ParallelCoordsApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>2025 commit activity</p>
      <CalendarHeatmapApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Stock price — zoom &amp; pan</p>
      <ZoomableLineApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Phyllotaxis — zoom &amp; mini map</p>
      <PhyllotaxisApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Salary distribution</p>
      <HistogramApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>MPG vs horsepower by origin</p>
      <SymbolScatterApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Frontend tech stack</p>
      <TidyTreeApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Product launch timeline</p>
      <TimelineApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Salary by level</p>
      <ViolinApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Indo-European language family</p>
      <RadialTreeApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>npm packages — downloads vs stars</p>
      <LogScatterApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Curve interpolation types</p>
      <CurveComparisonApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly revenue growth</p>
      <DivergingBarApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>API response times</p>
      <ThresholdBarApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Easing functions</p>
      <EasingCurvesApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Color space interpolation</p>
      <ColorSpacesApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Bivariate density contour</p>
      <DensityContourApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Voronoi diagram</p>
      <VoronoiDiagramApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Map projections</p>
      <MapProjectionsApp client:load noMeta />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>KPI vs targets</p>
      <BulletApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>JS framework rankings</p>
      <BumpApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>JS tooling dependency network</p>
      <ArcDiagramApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Experience vs salary — linked views</p>
      <LinkedChartsApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Developer survey — Likert responses</p>
      <DivergingStackedBarApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Tech stock return correlations</p>
      <CorrelationMatrixApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Wind frequency by direction</p>
      <WindRoseApp client:load />
    </div>
  </div>
</Layout>
