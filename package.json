{
  "name": "@opsydyn/astro-foldkit-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "bun run --filter @opsydyn/web dev",
    "build": "bun run --filter @opsydyn/astro-foldkit build && bun run --filter @opsydyn/web build",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  }
}
