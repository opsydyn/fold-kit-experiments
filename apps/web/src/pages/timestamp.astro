---
import { DateTime } from 'effect';

import TimestampApp from '../apps/timestamp/app';
import Layout from '../layouts/Layout.astro';
import * as layoutStyles from '../layouts/layout.css';
import { startedAt } from './api/health';
---

<Layout title="Timestamp — Astro + FoldKit">
  <h1 class={layoutStyles.heading}>Timestamp</h1>
  <TimestampApp client:load startedAt={DateTime.formatIso(startedAt)} />
</Layout>
