---
import AreaApp from '../apps/area/app';
import BarApp from '../apps/bar/app';
import BubbleApp from '../apps/bubble/app';
import DonutApp from '../apps/donut/app';
import ForceGraphApp from '../apps/force-graph/app';
import LineApp from '../apps/line/app';
import ScatterApp from '../apps/scatter/app';
import * as gridStyles from '../apps/charts/charts.css';
import Layout from '../layouts/Layout.astro';
import * as layoutStyles from '../layouts/layout.css';
---

<Layout title="Charts — Astro + FoldKit">
  <h1 class={layoutStyles.heading}>Charts</h1>
  <div class={gridStyles.grid}>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Budget breakdown</p>
      <DonutApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly figures</p>
      <BarApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly trend</p>
      <LineApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly revenue</p>
      <AreaApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Experience vs salary</p>
      <ScatterApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Price vs rating by sales</p>
      <BubbleApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>JS ecosystem</p>
      <ForceGraphApp client:load />
    </div>
  </div>
</Layout>
