---
import AreaApp from '../apps/area/app';
import BarApp from '../apps/bar/app';
import BubbleApp from '../apps/bubble/app';
import DonutApp from '../apps/donut/app';
import ForceGraphApp from '../apps/force-graph/app';
import ChordApp from '../apps/chord/app';
import SankeyApp from '../apps/sankey/app';
import HeatmapApp from '../apps/heatmap/app';
import RadarApp from '../apps/radar/app';
import StreamgraphApp from '../apps/streamgraph/app';
import SunburstApp from '../apps/sunburst/app';
import TreemapApp from '../apps/treemap/app';
import LineApp from '../apps/line/app';
import ScatterApp from '../apps/scatter/app';
import * as gridStyles from '../apps/charts/charts.css';
import Layout from '../layouts/Layout.astro';
import * as layoutStyles from '../layouts/layout.css';
---

<Layout title="Charts — Astro + FoldKit">
  <h1 class={layoutStyles.heading}>Charts</h1>
  <div class={gridStyles.grid}>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Budget breakdown</p>
      <DonutApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly figures</p>
      <BarApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly trend</p>
      <LineApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Monthly revenue</p>
      <AreaApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Experience vs salary</p>
      <ScatterApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Price vs rating by sales</p>
      <BubbleApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>JS ecosystem</p>
      <ForceGraphApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Language comparison</p>
      <RadarApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Tech revenue by segment</p>
      <TreemapApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>JS framework downloads</p>
      <StreamgraphApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Tech market cap by sector</p>
      <SunburstApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Traffic by hour &amp; day</p>
      <HeatmapApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>Tech sector cross-investment</p>
      <ChordApp client:load />
    </div>
    <div class={gridStyles.cell}>
      <p class={gridStyles.cellLabel}>UK energy flow</p>
      <SankeyApp client:load />
    </div>
  </div>
</Layout>
