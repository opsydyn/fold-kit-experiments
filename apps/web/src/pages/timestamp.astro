---
import { Schema } from 'effect';

import TimestampApp from '../apps/timestamp/app';
import { Iso8601 } from '../apps/timestamp/model';
import Layout from '../layouts/Layout.astro';
import * as layoutStyles from '../layouts/layout.css';

const res = await fetch(new URL('/api/health', Astro.url));
const { startedAt: raw } = (await res.json()) as { startedAt: string };
const startedAt = Schema.decodeSync(Iso8601)(raw);
---

<Layout title="Timestamp — Astro + FoldKit">
  <h1 class={layoutStyles.heading}>Timestamp</h1>
  <TimestampApp client:load startedAt={startedAt} />
</Layout>
