---
import * as styles from './layout.css';
import '../styles/chart-tokens.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
const path = new URL(Astro.request.url).pathname;

const linkClass = (href: string) =>
  href === path ? `${styles.navLink} ${styles.navLinkActive}` : styles.navLink;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // Restore theme before first paint to avoid flash
      const stored = localStorage.getItem('foldkit-theme');
      if (stored === 'light') document.documentElement.setAttribute('data-theme', 'light');
    </script>
  </head>
  <body>
    <nav class={styles.nav}>
      <a href="/" class={linkClass('/')}>Home</a>
      <a href="/health" class={linkClass('/health')}>Health</a>
      <a href="/greeting" class={linkClass('/greeting')}>Greeting</a>
      <a href="/timestamp" class={linkClass('/timestamp')}>Timestamp</a>
      <a href="/profile" class={linkClass('/profile')}>Profile</a>
      <a href="/welcome" class={linkClass('/welcome')}>Welcome</a>
      <a href="/carousel" class={linkClass('/carousel')}>Carousel</a>
      <a href="/charts" class={linkClass('/charts')}>Charts</a>
      <button id="theme-toggle" class={styles.themeToggle} aria-label="Toggle light/dark mode">◑</button>
    </nav>
    <main class={styles.main}>
      <slot />
    </main>
  </body>
</html>

<script>
  import { themeAtom, applyTheme } from '../stores/theme';

  // Sync store → DOM on every change
  themeAtom.subscribe(applyTheme);

  // Wire toggle button
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    themeAtom.set(themeAtom.get() === 'dark' ? 'light' : 'dark');
  });
</script>
