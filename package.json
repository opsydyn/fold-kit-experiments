{
  "name": "@opsydyn/astro-foldkit-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "bun run --filter @opsydyn/web dev",
    "build": "bun run --filter @opsydyn/astro-foldkit build && bun run --filter @opsydyn/web build",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "check": "biome check .",
    "storybook": "bun run --filter @opsydyn/web storybook",
    "check:fix": "biome check --write ."
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@foldkit/oxlint-plugin": "^0.2.0",
    "@opsydyn/oxlint-effect": "^0.4.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0"
  }
}
